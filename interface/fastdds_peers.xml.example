<?xml version="1.0" encoding="UTF-8"?>
<!--
  fastdds_peers.xml — Fast-DDS profile for cross-host discovery (laptop ↔ Pi).

  WHEN TO USE
  -----------
  ONLY needed when you're running ROS 2 on the laptop AND on a Raspberry Pi
  (or other peer host) and want them to discover each other across the LAN.

  For SINGLE-LAPTOP simulation (server.py + ros_pose_bridge.py +
  static_transform_publisher all on one machine, no Pi):
      DO NOT set FASTRTPS_DEFAULT_PROFILES_FILE.
      Fast-DDS's default multicast (224.0.0.1:7400) handles same-host
      discovery just fine, and the hardcoded LAN IP below would otherwise
      try to bind to a non-existent interface.

  HOW TO USE
  ----------
  1. Copy this file to ~/fastdds_peers.xml on every host that needs to
     participate (laptop AND Pi).
  2. Replace YOUR_LAPTOP_LAN_IP with the laptop's actual LAN IP. Find it
     with:  ip -4 addr show | grep 192.168.
     The Pi addresses (.101 / .102) below are the canonical pi1/pi2 IPs
     for the swerve project — change if your fleet differs.
  3. Export the env var BEFORE sourcing ROS or launching anything:
         export FASTRTPS_DEFAULT_PROFILES_FILE=~/fastdds_peers.xml
  4. After editing, restart the ros2 daemon on every host:
         ros2 daemon stop ; sleep 2 ; ros2 daemon start

  STRUCTURE NOTE
  --------------
  This is the BARE-BONES locator block, intended to be embedded into a
  full Fast-DDS profile. If your version of Fast-DDS requires a wrapping
  <profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  element, wrap the contents accordingly. See:
      https://fast-dds.docs.eprosima.com/en/latest/fastdds/xml_configuration/xml_configuration.html
-->

<initialPeersList>
  <!-- Loopback — required even on a single host so processes find each other -->
  <locator><udpv4><address>127.0.0.1</address>      <port>14910</port></udpv4></locator>
  <locator><udpv4><address>127.0.0.1</address>      <port>14912</port></udpv4></locator>

  <!-- pi1 (sensor / OpenCR head) -->
  <locator><udpv4><address>192.168.1.101</address>  <port>14910</port></udpv4></locator>
  <locator><udpv4><address>192.168.1.101</address>  <port>14912</port></udpv4></locator>

  <!-- pi2 (camera / OAK-D head) -->
  <locator><udpv4><address>192.168.1.102</address>  <port>14910</port></udpv4></locator>
  <locator><udpv4><address>192.168.1.102</address>  <port>14912</port></udpv4></locator>
</initialPeersList>

<!-- Pin metatraffic + default unicast to the laptop's LAN IP. Replace
     YOUR_LAPTOP_LAN_IP with the output of:  ip -4 addr show | grep 192.168. -->
<metatrafficUnicastLocatorList>
  <locator><udpv4><address>YOUR_LAPTOP_LAN_IP</address></udpv4></locator>
</metatrafficUnicastLocatorList>
<defaultUnicastLocatorList>
  <locator><udpv4><address>YOUR_LAPTOP_LAN_IP</address></udpv4></locator>
</defaultUnicastLocatorList>
